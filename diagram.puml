@startuml
skinparam classAttributeIconSize 0

class Зарождение {
    - игровая сессия
    - правила игры
    - история
    + main
    + run : транслирует команды и проверяет выход
}

class ИгроваяСессия {
    - id
    + статус сессии
    + список игроков
    + текущий игрок
    --
    + передать ход
    + применить действие
}

class ПравилаИгры {
    + правильный шаг?
    + проверить инварианты
    + конец?
}

class ИсторияМатча {
    - id
    + победитель
    + проигравшие
}

enum СтатусСессии {
    зарядка
    раздача предметов
    ход
    конецИгры
}

class Игрок {
    - id
    + имя
    + здоровье
    + статус
}

class Дробовик {
    - магазин
    + зарядить
    --
    + выстрелить
}

enum ТипПатрона {
    боевой
    холостой
}

class Инвентарь {
    + размер
    --
    + добавить предмет
}

class Статистика {
    + победы
    + винрейт
}

class Предмет {
    + название
    + эффект
}

Зарождение *-- ИгроваяСессия : создает в начале
Зарождение *-- ПравилаИгры : проверяет
Зарождение ..> ИсторияМатча : создает при выходе

ИгроваяСессия *-- СтатусСессии : имеет
ИгроваяСессия *-- Игрок
ИгроваяСессия *-- Дробовик : содержит

Игрок *-- Инвентарь : хранит
Игрок -- Статистика : имеет
Инвентарь o-- Предмет : содержит
Дробовик ..> ТипПатрона : имеет

@enduml
