@startuml
skinparam classAttributeIconSize 0

' --- Интерфейсы и Абстракции (I) ---

interface GameContext {
    + peekNextAmmo(): AmmoType
    + ejectAmmo(): AmmoType
    + healActivePlayer()
    + doubleNextDamage()
    + skipOpponent(target: Player)
    + getPhoneCall()
    + invertCurrentAmmo()
    + sendInfo(message: String)
}

interface Item {
    + name: String
    + applyEffect(context: GameContext, user: Player, target: Player? = null)
}

' --- Основные классы (C) ---

class AppLauncher {
    - currentSession: GameSession
    + main(args: Array<String>)
    + startNewGame()
    + handleGameEvent(event: GameEvent)
}

class GameSession implements GameContext{
    - id: UUID
    - status: SessionStatus
    - players: List<Player>
    - shotgun: Shotgun
    - currentPlayerIdx: Int
    
    + shot(target: Player)    
    + nextTurn()
    + checkGameCondition()
    
    + peekNextAmmo(): AmmoType
    + ejectAmmo(): AmmoType
    + healActivePlayer()
    + doubleNextDamage()
    + skipOpponent(target: Player)
    + getPhoneCall()
    + invertCurrentAmmo()
    + sendInfo(message: String)
    + useItem(player: Player, item: Item, target: Player? = null)
}

class Shotgun {
    - barrel: MutableList<AmmoType>
    + load(live: Int, blank: Int)
    + fire(): AmmoType
    + peek(): AmmoType
    + findFirstLive()
    + invertCurrentAmmo()
    + isEmpty(): Boolean
}

class Player {
    - id: UUID
    + name: String
    - health: Int
    - isCuffed: Boolean
    - isBuffed: Boolean
    - inventory: MutableList<Item>
    
    + takeDamage(value: Int)
    + heal(value: Int)
    + addItem(item: Item): Boolean
}

class Statistics {
    + wins: Int
    + totalGames: Int
    + calculateWinRate(): Double
}

class MatchHistory {
    - matchId: UUID
    + winnerId: UUID
    + losersId: List<UUID>
    + save()
}

' --- Перечисления (E) ---

enum AmmoType {
    LIVE
    BLANK
}

enum SessionStatus {
    LOADING
    DEALING
    PLAYER_TURN
    GAME_OVER
}

' --- Отношения и зависимости ---

AppLauncher "1" *-- "0..1" GameSession
GameSession "1" *-- "2..4" Player
GameSession "1" *-- "1" Shotgun
GameSession "1" *-- "1" SessionStatus

Item ..> GameContext
Player "1" *-- "1" Statistics
Player "1" o-- "0..8" Item

Shotgun ..> AmmoType
AppLauncher ..> MatchHistory

@enduml
